      "id": "project-04",
      "slug": "multilingual-resume-cms",
      "title": {
        "zh-TW": "多語系履歷 CMS",
        "en-US": "Multilingual Resume CMS"
      },
      "summary": {
        "zh-TW": "以 JSON + localStorage 模擬後台，支援多版本履歷內容管理。",
        "en-US": "Mocked an admin backend with JSON + localStorage for multilingual resume version management."
      },
      "problem": {
        "zh-TW": "一般履歷無法快速切換職務版本與語言。",
        "en-US": "A static resume cannot quickly switch roles, versions, or languages."
      },
      "solution": {
        "zh-TW": "設計前台 + 後台流程，加入登入、編輯、排序與列印。",
        "en-US": "Designed public and admin flows with auth, editing, sorting, and print support."
      },
      "impact": [
        {
          "zh-TW": "面試展示可直接切換情境，提升溝通效率",
          "en-US": "Scenario switching during interviews made communication faster"
        }
