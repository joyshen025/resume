  "projects": [
    {
      "id": "project-01",
      "slug": "his-form-builder",
      "title": {
        "zh-TW": "HIS 表單引擎重構",
        "en-US": "HIS Form Engine Revamp"
      },
      "summary": {
        "zh-TW": "把病歷表單做成可配置流程，降低重複開發成本。",
        "en-US": "Turned clinical forms into configurable flows to reduce repeated implementation."
      },
      "problem": {
        "zh-TW": "每個科別都有獨立表單流程，需求變動時維護成本高。",
        "en-US": "Each department had isolated form logic, making change requests expensive."
      },
      "solution": {
        "zh-TW": "以 JSON schema + 元件映射重建流程，支援欄位規則與權限。",
        "en-US": "Rebuilt flows with JSON schema + component mapping, including rules and permissions."
      },
      "impact": [
        {
          "zh-TW": "平均需求交付時間從 8 天降到 5 天",
          "en-US": "Average delivery time dropped from 8 days to 5 days"
        },
        {
          "zh-TW": "降低重複程式碼，提升可維護性",
          "en-US": "Reduced duplicated code and improved maintainability"
        }
      ],
      "tech": [
        "Vue 3",
        "Quasar",
        "REST API",
        "JSON Schema",
        "RBAC"
      ],
      "domainTags": [
        "HIS",
        "Workflow",
