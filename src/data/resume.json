  "projects": [
    {
      "id": "project-01",
      "slug": "his-system-development",
      "title": {
        "zh-TW": "醫療系統 HIS 開發",
        "en-US": "Healthcare HIS Development"
      },
      "summary": {
        "zh-TW": "負責 HIS 前端開發與功能優化，涵蓋門診掛號、報到、看診流程與醫療表單管理，並配合院內流程進行客製化 UI/UX 與邏輯實作。",
        "en-US": "Developed and optimized HIS frontend workflows including registration, check-in, clinical flow, and complex medical forms with customized UI/UX and business logic."
      },
      "problem": {
        "zh-TW": "大型醫療流程與高複雜度表單需兼顧效能與操作流暢度，且需整合硬體（健保卡讀卡機）與多種院內系統 API，任何流程不一致都可能造成櫃檯中斷或誤操作。",
        "en-US": "Complex clinical workflows and large forms required both performance and smooth UX, integrating hardware (NHI card reader) and multiple internal APIs; inconsistency could interrupt operations."
      },
      "solution": {
        "zh-TW": "以 Vue 3/Quasar 建立可維護的元件與表單結構，整合健保卡讀寫卡流程（解析/防呆/錯誤處理），並優化 API 呼叫與資料處理策略，避免重複請求與狀態不同步；同時整理共用元件與樣式規範提升一致性。",
        "en-US": "Built maintainable Vue 3/Quasar components and form structure, integrated NHI card read/write flows (parsing/validation/error handling), optimized API/data strategy to prevent duplicates and state drift, and established shared UI/style standards."
      },
      "impact": [
        {
          "zh-TW": "健保卡讀寫卡流程穩定化：降低錯誤與操作中斷風險",
          "en-US": "Stabilized NHI card read/write flows, reducing failure risk"
        },
        {
          "zh-TW": "API 呼叫流程優化：避免重複請求造成效能下降，提升操作流暢度",
          "en-US": "Optimized API calls to prevent duplicates and improve performance"
        },
        {
          "zh-TW": "元件/樣式規範化：降低重複邏輯與維護成本，提升一致性與擴充性",
          "en-US": "Standardized components/styles to reduce duplication and improve maintainability"
        },
        {
          "zh-TW": "改善大型表單渲染與表格操作體驗",
          "en-US": "Improved UX and rendering for large forms and tables"
        }
      ],
      "tech": [
